 	policy->max = policy->cpuinfo.max_freq = max_freq;
 
+	if (boot_cpu_data.x86_vendor == X86_VENDOR_AMD &&
+	    amd_max_boost(max_freq, &max_boost)) {
+		policy->cpuinfo.max_boost = max_boost;
+		static_branch_enable(&cpufreq_amd_max_boost);
+	}
+
 	if (policy->min == ~0)
 		return -EINVAL;
 	else
